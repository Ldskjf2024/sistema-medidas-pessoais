
CREATE DATABASE sistema_medidas;

USE sistema_medidas;

CREATE TABLE usuarios (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    email VARCHAR(100),
    senha VARCHAR(100),
    codigo_acesso VARCHAR(100)
);

CREATE TABLE medidas (
    id INT AUTO_INCREMENT PRIMARY KEY,
    usuario_id INT,
    busto FLOAT,
    torax FLOAT,
    cintura FLOAT,
    quadril FLOAT,
    coxa FLOAT,
    calcado INT,
    FOREIGN KEY (usuario_id) REFERENCES usuarios(id)
);